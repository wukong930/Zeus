# Zeus local development environment

ENVIRONMENT=development

# PostgreSQL + pgvector
POSTGRES_DB=zeus
POSTGRES_USER=zeus
POSTGRES_PASSWORD=zeus
POSTGRES_PORT=55432
DATABASE_URL=postgresql+asyncpg://zeus:zeus@localhost:55432/zeus

# Redis event bus
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379/0

# API
BACKEND_PORT=8000
CORS_ORIGINS=http://localhost:3000

# LLM providers (optional; DB config takes priority once enabled)
LLM_MODEL=
LLM_TIMEOUT_SECONDS=120
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
XAI_API_KEY=
XAI_BASE_URL=https://api.x.ai/v1
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://api.anthropic.com
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# Frontend
FRONTEND_PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:8000
BACKEND_INTERNAL_URL=http://localhost:8000

# Optional Weaviate profile:
# docker compose --profile weaviate up
WEAVIATE_PORT=8080
