# Zeus local development environment

ENVIRONMENT=development

# PostgreSQL + pgvector
POSTGRES_DB=zeus
POSTGRES_USER=zeus
POSTGRES_PASSWORD=zeus
POSTGRES_PORT=55432
DATABASE_URL=postgresql+asyncpg://zeus:zeus@localhost:55432/zeus

# Redis event bus
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379/0

# API
BACKEND_PORT=8000
CORS_ORIGINS=http://localhost:3000

# Frontend
FRONTEND_PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:8000
BACKEND_INTERNAL_URL=http://localhost:8000

# Optional Weaviate profile:
# docker compose --profile weaviate up
WEAVIATE_PORT=8080
