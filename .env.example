# Zeus local development environment

ENVIRONMENT=development

# PostgreSQL + pgvector
POSTGRES_DB=zeus
POSTGRES_USER=zeus
POSTGRES_PASSWORD=zeus
POSTGRES_PORT=55432
DATABASE_URL=postgresql+asyncpg://zeus:zeus@localhost:55432/zeus

# Redis event bus
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379/0

# API
BACKEND_PORT=8000
CORS_ORIGINS=http://localhost:3000

# LLM providers (optional; DB config takes priority once enabled)
LLM_MODEL=
LLM_TIMEOUT_SECONDS=120
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
XAI_API_KEY=
XAI_BASE_URL=https://api.x.ai/v1
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://api.anthropic.com
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# Free data sources
DATA_SOURCE_AKSHARE_ENABLED=false
DATA_SOURCE_AKSHARE_SYMBOLS=RB0,HC0,I0,J0,JM0,RU0,NR0,BR0,SC0,TA0,MA0,PP0,CU0,AL0,ZN0,NI0,M0,Y0,P0,AU0,AG0
DATA_SOURCE_AKSHARE_HISTORY_LIMIT=80
DATA_SOURCE_RUBBER_SPOT_ENABLED=false
DATA_SOURCE_RUBBER_SPOT_SYMBOLS=RU,NR,BR
DATA_SOURCE_RUBBER_SPOT_HISTORY_DAYS=7
DATA_SOURCE_RUBBER_TEXT_ENABLED=false
DATA_SOURCE_RUBBER_TEXT_MIN_CONFIDENCE=0.62
DATA_SOURCE_GDELT_ENABLED=false
DATA_SOURCE_GDELT_QUERY=commodities futures OR supply chain OR inventory
DATA_SOURCE_OPEN_METEO_ENABLED=false
OPEN_METEO_BASE_URL=https://api.open-meteo.com/v1/forecast
DATA_SOURCE_NASA_POWER_ENABLED=false
NASA_POWER_BASE_URL=https://power.larc.nasa.gov/api/temporal/daily/point
DATA_SOURCE_NASA_POWER_BASELINE_ENABLED=false
NASA_POWER_BASELINE_YEARS=5
NASA_POWER_BASELINE_WINDOW_DAYS=7
DATA_SOURCE_NOAA_CDO_ENABLED=false
NOAA_CDO_API_KEY=
NOAA_CDO_BASE_URL=https://www.ncei.noaa.gov/cdo-web/api/v2
NOAA_CDO_MAX_LOCATIONS_PER_RUN=3
NOAA_CDO_STATION_RADIUS_DEGREES=1.5
NOAA_CDO_MAX_STATION_CANDIDATES=5
DATA_SOURCE_ACCUWEATHER_ENABLED=false
ACCUWEATHER_API_KEY=
ACCUWEATHER_BASE_URL=https://dataservice.accuweather.com
ACCUWEATHER_MAX_LOCATIONS_PER_RUN=4
DATA_SOURCE_FRED_ENABLED=false
FRED_API_KEY=
FRED_BASE_URL=https://api.stlouisfed.org/fred

# Free-registration / optional data sources
DATA_SOURCE_EIA_ENABLED=false
EIA_API_KEY=
EIA_BASE_URL=https://api.eia.gov
DATA_SOURCE_TUSHARE_ENABLED=false
TUSHARE_TOKEN=
TUSHARE_BASE_URL=http://api.tushare.pro
DATA_SOURCE_TUSHARE_EXCHANGES=SHFE,DCE,CZCE,INE
DATA_SOURCE_TUSHARE_SYMBOLS=RB,HC,I,J,JM,RU,NR,BR,SC,TA,MA,PP,CU,AL,ZN,NI,M,Y,P,AU,AG

# Frontend
FRONTEND_PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:8000
BACKEND_INTERNAL_URL=http://localhost:8000

# Optional Weaviate profile:
# docker compose --profile weaviate up
WEAVIATE_PORT=8080
